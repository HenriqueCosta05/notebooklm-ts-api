# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_PREFIX=/api/v1

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
# Use * for development, restrict to your frontend origin in production
CORS_ORIGIN=*

# ─────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# ─────────────────────────────────────────────
# Request timeout
# ─────────────────────────────────────────────
REQUEST_TIMEOUT_MS=30000

# ─────────────────────────────────────────────
# NotebookLM authentication (one of the two below is required)
# ─────────────────────────────────────────────

# Option A — path to a Playwright storage_state.json file on disk
# NOTEBOOKLM_STORAGE_PATH=/home/user/.notebooklm/storage_state.json

# Option B — inline Playwright storage state as a JSON string
# NOTEBOOKLM_AUTH_JSON={"cookies":[...],"origins":[]}

# ─────────────────────────────────────────────
# NotebookLM client
# ─────────────────────────────────────────────
NOTEBOOKLM_TIMEOUT_MS=60000

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
# Accepted values: debug | info | warn | error
LOG_LEVEL=info
